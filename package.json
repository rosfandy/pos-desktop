{
  "name": "pos-desktop",
  "author": "rosfandy",
  "version": "1.5.3",
  "description": "POS Desktop - Aplikasi kasir untuk UMKM",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p electron/tsconfig.json",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:dir": "npm run build && electron-builder --dir -c electron-builder.dev.json",
    "electron:build:dev": "npm run build && electron-builder -c electron-builder.dev.json",
    "electron:publish": "npm run build && electron-builder --win --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/query-persist-client-core": "^5.100.14",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@types/jsonwebtoken": "^9.0.10",
    "apexcharts": "^5.13.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "electron-updater": "^6.8.3",
    "jiti": "^2.7.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.453.0",
    "node-thermal-printer": "^4.6.0",
    "phosphor-react": "^1.4.1",
    "react": "^18.3.1",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "shadcn": "^4.8.2",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/xlsx": "^0.0.35",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.26.2",
    "drizzle-orm": "^0.35.3",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^8.0.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.posdesktop.app",
    "productName": "POS Desktop",
    "copyright": "Copyright © 2026",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "electron/database/migrations",
        "to": "data",
        "filter": [
          "**/*.sql"
        ]
      },
      {
        "from": "build-resources/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.png",
      "publisherName": "POS Desktop",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POS Desktop",
      "include": "build-resources/installer.nsh",
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "rosfandy",
      "repo": "pos-desktop",
      "releaseType": "release"
    }
  }
}
