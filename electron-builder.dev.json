{
  "appId": "com.poskasir.app",
  "productName": "POS Kasir",
  "copyright": "Copyright © 2026",
  "asar": false,
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "!**/*.map",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "database/migrations",
      "to": "migrations",
      "filter": ["**/*.sql"]
    },
    {
      "from": "build-resources/icon.png",
      "to": "icon.png"
    }
  ],
  "win": {
    "target": ["portable"],
    "icon": "icon.ico",
    "publisherName": "POS Kasir",
    "publish": null
  }
}
